  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@nuxt/ui": "4.5.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "fflate": "^0.8.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "nuxt": "^4.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^9.0.7",
    "vitest": "^4.1.0"
  }
