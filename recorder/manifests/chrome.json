{
  "manifest_version": 3,
  "name": "bugreel",
  "version": "1.0.0",
  "description": "Record DOM, console, and network for bug reporting",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "webRequest",
    "downloads",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "bugreel",
    "default_icon": { "48": "icons/icon48.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/rrweb.min.js", "lib/fflate.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
